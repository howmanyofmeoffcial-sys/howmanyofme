{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "statusCode": 308,
      "regex": "^(?!/_next)(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/(?:/)?$"
    },
    {
      "source": "/blog/how-many-people-have-my-name-questions",
      "destination": "/#faq",
      "statusCode": 308,
      "regex": "^(?!/_next)/blog/how-many-people-have-my-name-questions(?:/)?$"
    },
    {
      "source": "/blog/baby-name-trends-2026",
      "destination": "/blog/baby-name-trends",
      "statusCode": 308,
      "regex": "^(?!/_next)/blog/baby-name-trends-2026(?:/)?$"
    },
    {
      "source": "/blog/baby-name-trends-:year(20\\d{2})",
      "destination": "/blog/baby-name-trends",
      "statusCode": 308,
      "regex": "^(?!/_next)/blog/baby-name-trends-(20\\d{2})(?:/)?$"
    },
    {
      "source": "/blog/top-google-baby-name-searches-2026",

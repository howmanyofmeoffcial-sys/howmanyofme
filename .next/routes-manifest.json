    },
    {
      "source": "/blog/top-google-baby-name-searches-:year(20\\d{2})",
      "destination": "/blog/top-google-baby-name-searches",
      "statusCode": 308,
      "regex": "^(?!/_next)/blog/top-google-baby-name-searches-(20\\d{2})(?:/)?$"
    },
    {
      "source": "/blog/popular-baby-names-california-2026",

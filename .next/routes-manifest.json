      "statusCode": 308,
      "regex": "^(?!/_next)/blog/popular-baby-names-california-2026(?:/)?$"
    },
    {
      "source": "/blog/popular-baby-names-california-:year(20\\d{2})",
      "destination": "/blog/popular-baby-names-california",
      "statusCode": 308,
      "regex": "^(?!/_next)/blog/popular-baby-names-california-(20\\d{2})(?:/)?$"
    },
    {

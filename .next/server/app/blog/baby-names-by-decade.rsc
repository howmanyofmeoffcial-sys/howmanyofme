35:["$","div","3",{"className":"mb-8","children":[["$","h2","0",{"className":"font-display text-2xl font-bold mt-8 mb-4 text-foreground","children":"The 1940s–1950s: The Baby Boom Classics"}],null,["$","p","2",{"className":"text-muted-foreground leading-relaxed mb-3","children":["",["$","strong","1",{"className":"text-foreground font-semibold","children":"Top names"}],": James, Robert, Michael, Linda, Barbara, Patricia"]}],null,["$","p","4",{"className":"text-muted-foreground leading-relaxed mb-3","children":["Post-war optimism produced both a baby boom and a naming boom. Linda exploded from obscurity to #1 in 1947, possibly influenced by the song 'Linda.' This era favored solid, dependable names reflecting stability values."]}]]}]
36:["$","div","4",{"className":"mb-8","children":[["$","h2","0",{"className":"font-display text-2xl font-bold mt-8 mb-4 text-foreground","children":"The 1960s–1970s: The Creative Revolution"}],null,["$","p","2",{"className":"text-muted-foreground leading-relaxed mb-3","children":["",["$","strong","1",{"className":"text-foreground font-semibold","children":"Top names"}],": Michael, David, Jennifer, Amy"]}],null,["$","p","4",{"className":"text-muted-foreground leading-relaxed mb-3","children":["Jennifer's rise is one of the most dramatic in naming history — from relative obscurity to absolute dominance by 1970, where it remained #1 for 15 consecutive years. The hippie movement introduced nature names and creative spellings."]}],null,["$","h2","6",{"className":"font-display text-2xl font-bold mt-8 mb-4 text-foreground","children":"The 1980s–1990s: The Soap Opera Era"}],null,["$","p","8",{"className":"text-muted-foreground leading-relaxed mb-3","children":["",["$","strong","1",{"className":"text-foreground font-semibold","children":"Top names"}],": Michael, Christopher, Jessica, Ashley"]}],null,["$","p","10",{"className":"text-muted-foreground leading-relaxed mb-3","children":["Television dominated naming. Dynasty, Dallas, and daytime soaps influenced millions. Jessica (from a Merchant of Venice character popularized by soap operas) and Ashley (from The Young and the Restless) defined a generation."]}]]}]
37:["$","div","5",{"className":"mb-8","children":[["$","h2","0",{"className":"font-display text-2xl font-bold mt-8 mb-4 text-foreground","children":"The 2000s: The Celebrity Era"}],null,["$","p","2",{"className":"text-muted-foreground leading-relaxed mb-3","children":["",["$","strong","1",{"className":"text-foreground font-semibold","children":"Top names"}],": Jacob, Emily"]}],null,["$","p","4",{"className":"text-muted-foreground leading-relaxed mb-3","children":["Jacob's rise coincided with the Twilight phenomenon. Emily represented a return to classics after decades of trendy names. This decade also saw the rise of surname-as-first-name (Madison, Taylor, Morgan)."]}],null,["$","h2","6",{"className":"font-display text-2xl font-bold mt-8 mb-4 text-foreground","children":"The 2010s–2020s: The Uniqueness Era"}],null,["$","p","8",{"className":"text-muted-foreground leading-relaxed mb-3","children":["",["$","strong","1",{"className":"text-foreground font-semibold","children":"Top names"}],": Liam, Noah, Emma, Olivia"]}],null,["$","p","10",{"className":"text-muted-foreground leading-relaxed mb-3","children":["Name concentration hit historic lows. Parents prioritized uniqueness, creating an explosion of name diversity. International names, gender-neutral options, and creative spellings all flourished."]}]]}]

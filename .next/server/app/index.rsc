21:["$","div",null,{"className":"border-t border-border mt-8 pt-6","children":["$","div",null,{"className":"max-w-2xl mx-auto text-center","children":[["$","p",null,{"className":"text-sm font-semibold text-foreground mb-2","children":"Built by Ziven Borceg"}],["$","p",null,{"className":"text-sm text-muted-foreground leading-relaxed mb-3","children":"Hi, I'm Ziven Borceg. Welcome to howmanyofme.co — your all-in-one platform to discover how many people around the world share your first or last name, explore name popularity trends, and uncover the origins and meaning behind names."}],["$","a",null,{"href":"https://medium.com/@zivenborceg","target":"_blank","rel":"noopener noreferrer","className":"inline-flex items-center gap-1.5 text-sm text-primary hover:text-primary/80 transition-colors font-medium","children":["Follow me on Medium",["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-external-link h-3.5 w-3.5","children":[["$","path","1q9fwt",{"d":"M15 3h6v6"}],["$","path","gplh6r",{"d":"M10 14 21 3"}],["$","path","a6xqqp",{"d":"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"}],"$undefined"]}]]}]]}]}]
